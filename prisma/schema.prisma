// prisma/schema.prisma
// RDPR OS - Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// ORGANIZACIÓN / HOLDING
// ─────────────────────────────────────────────
model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  type      OrgType  @default(CLIENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies Company[]

  @@map("organizations")
}

enum OrgType {
  HOLDING
  CLIENT
}

enum TaxEntityType {
  AUTONOMO
  SL
  SA
  OTHER
}

enum VatFilingPeriod {
  QUARTERLY
  MONTHLY
}

enum IrpfRegime {
  DIRECT_ESTIMATION
  OBJECTIVE_MODULES
}

// ─────────────────────────────────────────────
// EMPRESA / COMPANY
// ─────────────────────────────────────────────
model Company {
  id             String   @id @default(cuid())
  organizationId String?
  name           String
  legalName      String?  // Razón social (facturación, AEAT, eFactura)
  slug           String?  @unique
  brandColor     String?  @default("#6570f3")
  taxId          String?  // NIF / CIF
  email          String?
  phone          String?
  address        String?
  city           String?
  postalCode     String?
  country        String   @default("ES")
  logoUrl        String?
  website        String?
  currency       String   @default("EUR")
  taxRate        Float    @default(21)
  // Perfil fiscal España (RDPR Tax Intelligence)
  taxEntityType  TaxEntityType   @default(SL)
  vatFilingPeriod VatFilingPeriod @default(QUARTERLY)
  irpfRegime     IrpfRegime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  users        UserCompany[]
  customers    Customer[]
  projects     Project[]
  invoices     Invoice[]
  documents    Document[]
  activityLogs ActivityLog[]
  accounts     ChartOfAccount[]
  journalEntries JournalEntry[]
  expenses     Expense[]
  bankAccounts BankAccount[]
  brands       Brand[]
  documentFolders DocumentFolder[]
  portalAccesses ClientPortalAccess[]
  employees      Employee[]
  payrollRuns    PayrollRun[]
  legalTemplates LegalTemplate[]
  legalCases     LegalCase[]

  @@map("companies")
}

// ─────────────────────────────────────────────
// MARCAS COMERCIALES (bajo una razón social)
// ─────────────────────────────────────────────
enum BrandType {
  MAIN       // Marca paraguas (RDPR)
  PRODUCT    // Producto / módulo (RDPR Finance, RDPR CRM…)
  STANDALONE // Marca especializada (CourtManager Pro, BOOKIA…)
}

model Brand {
  id         String    @id @default(cuid())
  companyId  String
  name       String
  slug       String
  type       BrandType @default(PRODUCT)
  tagline    String?
  brandColor String    @default("#6570f3")
  sortOrder  Int       @default(0)
  active     Boolean   @default(true)
  parentId   String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent   Brand?    @relation("BrandTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Brand[]   @relation("BrandTree")
  invoices Invoice[]
  projects Project[]

  @@unique([companyId, slug])
  @@map("brands")
}

// ─────────────────────────────────────────────
// USUARIOS
// ─────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  avatarUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  companies     UserCompany[]
  assignedTasks Task[]
  activityLogs  ActivityLog[]
  accounts      Account[]
  sessions      Session[]
  portalAccess  ClientPortalAccess[]

  @@map("users")
}

model UserCompany {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  role      Role     @default(EMPLOYEE)
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@map("user_companies")
}

enum Role {
  ADMIN
  EMPLOYEE
}

// ─────────────────────────────────────────────
// AUTH (NextAuth)
// ─────────────────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────
// CRM - CLIENTES
// ─────────────────────────────────────────────
model Customer {
  id          String          @id @default(cuid())
  companyId   String
  name        String
  email       String?
  phone       String?
  address     String?
  city        String?
  taxId       String?
  notes       String?         @db.Text
  pipelineStage PipelineStage @default(NEW_CONTACT)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projects  Project[]
  invoices  Invoice[]
  documents Document[]
  folders   DocumentFolder[]
  portalAccess ClientPortalAccess[]
  employees Employee[]
  legalCases LegalCase[]

  @@map("customers")
}

enum PipelineStage {
  NEW_CONTACT
  QUOTE_SENT
  CLIENT_WON
  CLIENT_LOST
}

// ─────────────────────────────────────────────
// PROYECTOS
// ─────────────────────────────────────────────
model Project {
  id          String        @id @default(cuid())
  companyId   String
  brandId     String?
  customerId  String?
  name        String
  description String?       @db.Text
  status      ProjectStatus @default(PENDING)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  brand     Brand?     @relation(fields: [brandId], references: [id], onDelete: SetNull)
  customer  Customer?  @relation(fields: [customerId], references: [id])
  tasks     Task[]
  documents Document[]

  @@map("projects")
}

enum ProjectStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Task {
  id          String       @id @default(cuid())
  projectId   String
  assignedTo  String?
  title       String
  description String?      @db.Text
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(TODO)
  dueDate     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee User?   @relation(fields: [assignedTo], references: [id])

  @@map("tasks")
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

// ─────────────────────────────────────────────
// FACTURACIÓN
// ─────────────────────────────────────────────
model Invoice {
  id         String        @id @default(cuid())
  companyId  String
  brandId    String?
  customerId String
  number     String        // e.g. FAC-2024-001
  documentType InvoiceDocumentType @default(INVOICE)
  status     InvoiceStatus @default(PENDING)
  issueDate  DateTime      @default(now())
  dueDate    DateTime?
  notes      String?       @db.Text
  subtotal   Float
  taxRate    Float         @default(21)
  taxAmount  Float
  total      Float
  withholdingRate   Float?  // Retención IRPF % (modelo 111)
  withholdingAmount Float?
  paidAt     DateTime?
  reminderSentAt DateTime?
  // eFactura / cumplimiento fiscal España
  electronicStatus  ElectronicInvoiceStatus @default(ISSUED)
  electronicFormat  ElectronicInvoiceFormat?
  complianceHash    String?   // Huella Verifactu / Ley Antifraude (v1)
  signedAt          DateTime?
  electronicSentAt  DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  company  Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  brand    Brand?        @relation(fields: [brandId], references: [id], onDelete: SetNull)
  customer Customer      @relation(fields: [customerId], references: [id])
  items    InvoiceItem[]

  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Float   @default(1)
  unitPrice   Float
  total       Float

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum InvoiceDocumentType {
  INVOICE
  QUOTE
  DELIVERY_NOTE
  CREDIT_NOTE
}

enum ElectronicInvoiceStatus {
  DRAFT
  ISSUED
  SIGNED
  SENT
  REGISTERED
  REJECTED
}

enum ElectronicInvoiceFormat {
  PDF
  FACTURAE_3_2
  UBL_2_1
  CII
}

// ─────────────────────────────────────────────
// DOCUMENTOS
// ─────────────────────────────────────────────
model Document {
  id         String         @id @default(cuid())
  companyId  String
  customerId String?
  projectId  String?
  folderId   String?
  legalCaseId String?
  name       String
  fileUrl    String
  fileType   String
  fileSize   Int
  tags       String[]       @default([])
  source     DocumentSource @default(INTERNAL)
  createdAt  DateTime       @default(now())

  company  Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer?       @relation(fields: [customerId], references: [id])
  project  Project?        @relation(fields: [projectId], references: [id])
  folder   DocumentFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  legalCase LegalCase?     @relation(fields: [legalCaseId], references: [id], onDelete: SetNull)

  @@map("documents")
}

enum DocumentSource {
  INTERNAL
  PORTAL
}

model DocumentFolder {
  id         String   @id @default(cuid())
  companyId  String
  customerId String?
  name       String
  parentId   String?
  createdAt  DateTime @default(now())

  company   Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer  Customer?        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  parent    DocumentFolder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  DocumentFolder[] @relation("FolderTree")
  documents Document[]

  @@map("document_folders")
}

model ClientPortalAccess {
  id         String   @id @default(cuid())
  userId     String
  companyId  String
  customerId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([userId, customerId])
  @@map("client_portal_access")
}

// ─────────────────────────────────────────────
// LOGS DE ACTIVIDAD
// ─────────────────────────────────────────────
model ActivityLog {
  id        String   @id @default(cuid())
  companyId String
  userId    String?
  action    String   // e.g. "INVOICE_CREATED", "CUSTOMER_UPDATED"
  entity    String   // e.g. "Invoice", "Customer"
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@map("activity_logs")
}

// ─────────────────────────────────────────────
// CONTABILIDAD (Fase 2)
// ─────────────────────────────────────────────
model ChartOfAccount {
  id        String      @id @default(cuid())
  companyId String
  code      String      // PGC: 430, 477, 572, 705…
  name      String
  type      AccountType
  active    Boolean     @default(true)
  createdAt DateTime    @default(now())

  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines   JournalLine[]

  @@unique([companyId, code])
  @@map("chart_of_accounts")
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

model JournalEntry {
  id          String        @id @default(cuid())
  companyId   String
  number      String        // AST-2026-0001
  date        DateTime      @default(now())
  description String
  source      JournalSource @default(MANUAL)
  sourceId    String?       // invoice id, etc.
  createdAt   DateTime      @default(now())

  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines   JournalLine[]

  @@unique([companyId, source, sourceId])
  @@unique([companyId, number])
  @@map("journal_entries")
}

enum JournalSource {
  MANUAL
  INVOICE_ISSUE
  INVOICE_PAYMENT
  EXPENSE_ISSUE
  EXPENSE_PAYMENT
}

model JournalLine {
  id          String  @id @default(cuid())
  entryId     String
  accountId   String
  description String?
  debit       Float   @default(0)
  credit      Float   @default(0)

  entry   JournalEntry   @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account ChartOfAccount @relation(fields: [accountId], references: [id])

  @@map("journal_lines")
}

// ─────────────────────────────────────────────
// GASTOS / COMPRAS (Fase 2b)
// ─────────────────────────────────────────────
model Expense {
  id          String          @id @default(cuid())
  companyId   String
  description String
  vendor      String?
  vendorTaxId String?         // NIF proveedor (modelo 347)
  category    ExpenseCategory @default(SERVICES)
  status      ExpenseStatus   @default(PENDING)
  issueDate   DateTime        @default(now())
  paidAt      DateTime?
  subtotal    Float
  taxRate     Float           @default(21)
  taxAmount   Float
  total       Float
  withholdingRate   Float?
  withholdingAmount Float?
  notes       String?         @db.Text
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("expenses")
}

enum ExpenseCategory {
  SERVICES
  SUPPLIES
  BANK_FEES
  RENT
  OTHER
}

enum ExpenseStatus {
  PENDING
  PAID
  CANCELLED
}

// ─────────────────────────────────────────────
// BANCA / CONCILIACIÓN (Fase 3)
// ─────────────────────────────────────────────
model BankAccount {
  id        String   @id @default(cuid())
  companyId String
  name      String
  iban      String?
  bankName  String?
  createdAt DateTime @default(now())

  company      Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  transactions BankTransaction[]

  @@map("bank_accounts")
}

model BankTransaction {
  id              String            @id @default(cuid())
  companyId       String
  bankAccountId   String
  date            DateTime
  description     String
  amount          Float             // positivo = entrada, negativo = salida
  reference       String?
  status          BankTxStatus      @default(UNMATCHED)
  matchedInvoiceId String?
  matchedExpenseId String?
  importBatchId   String?
  createdAt       DateTime          @default(now())

  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  @@map("bank_transactions")
}

enum BankTxStatus {
  UNMATCHED
  MATCHED
  IGNORED
}

// ─────────────────────────────────────────────
// PAYROLL (Sprint 2 — Q4 MVP)
// ─────────────────────────────────────────────
model Employee {
  id           String    @id @default(cuid())
  companyId    String
  customerId   String?
  firstName    String
  lastName     String
  nif          String
  contractType String    @default("INDEFINIDO")
  startDate    DateTime
  endDate      DateTime?
  baseSalary   Float
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer     Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  payrollLines PayrollLine[]

  @@map("employees")
}

enum PayrollStatus {
  DRAFT
  CONFIRMED
  PAID
}

model PayrollRun {
  id        String        @id @default(cuid())
  companyId String
  period    String
  status    PayrollStatus @default(DRAFT)
  notes     String?       @db.Text
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines   PayrollLine[]

  @@unique([companyId, period])
  @@map("payroll_runs")
}

model PayrollLine {
  id           String  @id @default(cuid())
  payrollRunId String
  employeeId   String
  gross        Float
  deductions   Float   @default(0)
  net          Float
  notes        String?

  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([payrollRunId, employeeId])
  @@map("payroll_lines")
}

// ─────────────────────────────────────────────
// LEGAL (Sprint 2 — v0)
// ─────────────────────────────────────────────
enum LegalCaseStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

model LegalTemplate {
  id        String   @id @default(cuid())
  companyId String
  title     String
  category  String
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("legal_templates")
}

model LegalCase {
  id         String          @id @default(cuid())
  companyId  String
  customerId String?
  title      String
  status     LegalCaseStatus @default(OPEN)
  notes      String?         @db.Text
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer  Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  documents Document[]

  @@map("legal_cases")
}

// ─────────────────────────────────────────────
// WEB PÚBLICA — contacto y documentos seguros
// ─────────────────────────────────────────────
model ContactInquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  createdAt DateTime @default(now())

  @@map("contact_inquiries")
}

model SecureUpload {
  id            String   @id @default(cuid())
  uploaderName  String
  uploaderEmail String
  fileName      String
  fileType      String
  fileSize      Int
  storageKey    String
  iv            String
  authTag       String
  createdAt     DateTime @default(now())

  @@map("secure_uploads")
}
