# ─────────────────────────────────────────────
# RDPR OS - Variables de Entorno
# Copia este archivo como .env.local y rellena los valores
# ─────────────────────────────────────────────

# Base de datos PostgreSQL (Supabase recomendado)
# Runtime en Vercel — pooler puerto 6543 + pgbouncer:
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Migraciones / db:push — conexión directa puerto 5432:
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# NextAuth v5 (Auth.js)
# Genera AUTH_SECRET con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="cambia-esto-por-un-secreto-seguro-de-32-caracteres"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Compatibilidad con nombres antiguos (opcional)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="cambia-esto-por-un-secreto-seguro-de-32-caracteres"

# Cifrado documentos públicos (AES-256-GCM). Si no se define, usa AUTH_SECRET.
DOCUMENT_ENCRYPTION_SECRET=""

# Stripe (pagos — activar tras constitución SL)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Almacenamiento (Cloudflare R2 o Amazon S3)
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_BUCKET_NAME="rdpr-os-docs"
STORAGE_ENDPOINT=""         # Para R2: https://<account-id>.r2.cloudflarestorage.com
NEXT_PUBLIC_STORAGE_PUBLIC_URL=""

# Email (Resend — notificaciones portal y recordatorios fiscales)
RESEND_API_KEY=""
EMAIL_FROM="RDPR OS <noreply@rdpr.es>"

# Cron Vercel / recordatorios fiscales (GET /api/cron/tax-reminders)
CRON_SECRET=""

# Registro público: "true" desactiva /register salvo enlace ?invite=TOKEN
INVITE_ONLY="false"
REGISTRATION_INVITE_TOKEN=""

# AEAT / Verifactu (modo test por defecto — prod requiere certificado)
AEAT_VERIFACTU_MODE="test"
AEAT_CERTIFICATE_REF=""
AEAT_VERIFACTU_QR_BASE="https://rdpr.es/verifactu/verify"

# Firma electrónica — webhook proveedor
SIGNATURE_WEBHOOK_SECRET=""

# Email SMTP alternativo (opcional, no usado si Resend está activo)
# SMTP_HOST=""
# SMTP_PORT=587
# SMTP_USER=""
# SMTP_PASSWORD=""
# SMTP_FROM="noreply@tudominio.com"
