{
  "name": "rdpr-os",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && npm run auth:check && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "auth:check": "npx tsx scripts/auth-preflight.ts",
    "test": "node --import tsx --test __tests__/sprint-a.test.ts __tests__/fase1-gestoria.test.ts __tests__/fase2-5-automation.test.ts __tests__/firm-billing.test.ts"
  },
